# ============================================
# SOCIALGENIUS / MERITLIVES BACKEND
# Production Environment Template
# ============================================
# Copy this file to `.env.production` or your hosting provider's environment settings,
# then replace placeholders with real values. Never commit live secrets.

# ============================================
# APP / SERVER
# ============================================
PORT=4000
NODE_ENV=production
BACKEND_URL=https://api.yourdomain.com
CLIENT_URL=https://app.yourdomain.com
FRONTEND_URL=https://app.yourdomain.com

# ============================================
# DATABASE
# ============================================
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/meritlives-tools?retryWrites=true&w=majority

# ============================================
# AUTH / JWT
# ============================================
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRATION=7d

# ============================================
# GOOGLE AUTH
# ============================================
GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret
GOOGLE_REDIRECT_URI=https://api.yourdomain.com/api/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=replace_with_google_client_id
GOOGLE_OAUTH_CLIENT_SECRET=replace_with_google_client_secret

# ============================================
# SMTP / EMAIL
# ============================================
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=replace_with_brevo_user
BREVO_SMTP_PASS=replace_with_brevo_password
EMAIL_FROM=noreply@yourdomain.com
SUPPORT_EMAIL=support@yourdomain.com

# ============================================
# AI / EXTERNAL SERVICES
# ============================================
DEEPSEEK_API_KEY=replace_with_deepseek_key
OPENAI_API_KEY=replace_with_openai_key

# ============================================
# SOCIAL OAUTH / PUBLISHING
# ============================================
TOKEN_ENCRYPTION_KEY=replace_with_32_character_minimum_secret

# Meta (Facebook + Instagram)
META_APP_ID=replace_with_meta_app_id
META_APP_SECRET=replace_with_meta_app_secret
META_REDIRECT_URI=https://api.yourdomain.com/api/social/meta/callback

# LinkedIn
LINKEDIN_CLIENT_ID=replace_with_linkedin_client_id
LINKEDIN_CLIENT_SECRET=replace_with_linkedin_client_secret
LINKEDIN_REDIRECT_URI=https://api.yourdomain.com/api/social/linkedin/callback
LINKEDIN_VERSION=202504

# X / Twitter
TWITTER_CLIENT_ID=replace_with_twitter_client_id
TWITTER_CLIENT_SECRET=replace_with_twitter_client_secret
TWITTER_REDIRECT_URI=https://api.yourdomain.com/api/social/twitter/callback

# TikTok
TIKTOK_CLIENT_KEY=replace_with_tiktok_client_key
TIKTOK_CLIENT_SECRET=replace_with_tiktok_client_secret
TIKTOK_REDIRECT_URI=https://api.yourdomain.com/api/social/tiktok/callback

# Pinterest
PINTEREST_CLIENT_ID=replace_with_pinterest_client_id
PINTEREST_CLIENT_SECRET=replace_with_pinterest_client_secret
PINTEREST_REDIRECT_URI=https://api.yourdomain.com/api/social/pinterest/callback

# YouTube
YOUTUBE_CLIENT_ID=replace_with_youtube_client_id
YOUTUBE_CLIENT_SECRET=replace_with_youtube_client_secret
YOUTUBE_REDIRECT_URI=https://api.yourdomain.com/api/social/youtube/callback

# ============================================
# PAYSTACK
# ============================================
PAYSTACK_SECRET_KEY=sk_live_replace_with_real_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_live_replace_with_real_paystack_public_key
PAYSTACK_PLAN_BASIC_MONTHLY=PLN_replace_with_basic_monthly_plan_code
PAYSTACK_PLAN_PREMIUM_MONTHLY=PLN_replace_with_premium_monthly_plan_code
PAYSTACK_PLAN_BASIC_YEARLY=PLN_replace_with_basic_yearly_plan_code
PAYSTACK_PLAN_PREMIUM_YEARLY=PLN_replace_with_premium_yearly_plan_code
PAYSTACK_PLAN_PRO_MONTHLY=PLN_replace_with_pro_monthly_plan_code

# ============================================
# PAYPAL
# ============================================
# Live base URL: https://api-m.paypal.com
# Sandbox base URL: https://api-m.sandbox.paypal.com
# For sandbox checkout testing, CLIENT_ID and CLIENT_SECRET are enough.
# For recurring PayPal subscriptions, create PayPal billing plans and add the P-... plan IDs below.
PAYPAL_BASE_URL=https://api-m.paypal.com
PAYPAL_CLIENT_ID=replace_with_paypal_client_id
PAYPAL_CLIENT_SECRET=replace_with_paypal_client_secret
PAYPAL_PLAN_BASIC=P-replace-with-basic-plan-id
PAYPAL_PLAN_PREMIUM=P-replace-with-premium-plan-id
PAYPAL_PLAN_PRO=P-replace-with-pro-plan-id
PAYPAL_WEBHOOK_ID=replace_with_paypal_webhook_id

# ============================================
# OPTIONAL LEGACY / FUTURE PAYMENT KEYS
# ============================================
STRIPE_SECRET_KEY=optional_if_you_restore_stripe_later

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FILE=./logs/app.log
ERROR_LOG_FILE=./logs/error.log
LOG_DIRECTORY=./logs

# ============================================
# FILES / UPLOADS
# ============================================
UPLOAD_PATH=./uploads
