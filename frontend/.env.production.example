# ============================================
# SOCIALGENIUS / MERITLIVES FRONTEND
# Production Environment Template
# ============================================
#
# Copy this file to `.env.production` in the frontend app and replace
# placeholders with real values before building for production.

# Backend API base URL
REACT_APP_API_URL=https://api.yourdomain.com/api

# Optional analytics
REACT_APP_GA_ID=G-XXXXXXXXXX
REACT_APP_FB_PIXEL_ID=123456789012345

# Optional direct Paystack public key
# The current checkout flow mainly reads provider data from the backend,
# but this is still referenced by the legacy Paystack component.
REACT_APP_PAYSTACK_PUBLIC_KEY=pk_live_replace_with_real_paystack_public_key
